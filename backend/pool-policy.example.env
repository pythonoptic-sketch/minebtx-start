# BTX Start backend pool policy template.
# Replace the address placeholders only after scripts/create-platform-fee-wallet.sh
# has been run on the custody machine and platform-treasury.json has been updated.

PUBLIC_STRATUM_HOST=stratum.drinknile.com
PUBLIC_STRATUM_PORT=3333
PUBLIC_STATS_URL=https://api.drinknile.com/stats

POOL_FEE_BPS=0
FEE_ADDRESS=<BTX_START_PLATFORM_FEE_ADDRESS>
TREASURY_ADDRESS=<BTX_START_PLATFORM_TREASURY_ADDRESS>

# Comma- or space-separated miner payout addresses that must never be used as
# backend fee, treasury, hot wallet, or payout-aggregation addresses.
#
# Keep real values in a local env file, not git:
#   PROTECTED_PAYOUT_ADDRESSES=btx1z...personal...,btx1z...vast...
PROTECTED_PAYOUT_ADDRESSES=

# Public cutover gate. Keep false until scripts/verify-owned-backend.sh passes
# against the production stats API and stratum endpoint.
OWNED_BACKEND_ACTIVE=false

# Public treasury purpose if fees are later enabled:
# Fund BTX Start infrastructure, security, miner tooling, and collectively
# selected new BTX projects. This is not a miner dividend or profit-share.
