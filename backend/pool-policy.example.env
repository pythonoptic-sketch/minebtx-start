# BTX Start backend pool policy template.
# Replace the address placeholders only after scripts/create-platform-fee-wallet.sh
# has been run on the custody machine and platform-treasury.json has been updated.

POOL_FEE_BPS=0
FEE_ADDRESS=<BTX_START_PLATFORM_FEE_ADDRESS>
TREASURY_ADDRESS=<BTX_START_PLATFORM_TREASURY_ADDRESS>

# Public treasury purpose if fees are later enabled:
# Fund BTX Start infrastructure, security, miner tooling, and collectively
# selected new BTX projects. This is not a miner dividend or profit-share.
