[Unit]
Description=BTX Start payout dry-run planner
After=network-online.target btxd.service
Wants=network-online.target

[Service]
Type=oneshot
User=btxstart
Group=btxstart
WorkingDirectory=/opt/btx-start
EnvironmentFile=/etc/btx-start/backend.env
ExecStart=/opt/btx-start/.venv/bin/btxstart-payouts
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ReadWritePaths=/var/lib/btx-start
