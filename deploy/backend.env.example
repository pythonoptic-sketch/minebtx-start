# Copy to /etc/btx-start/backend.env on the backend server.
# Never commit the filled file.

BTX_START_DATABASE_PATH=/var/lib/btx-start/backend.sqlite3

PUBLIC_STRATUM_HOST=stratum.drinknile.com
PUBLIC_STRATUM_PORT=3333
PUBLIC_STATS_URL=https://api.drinknile.com/stats

OWNED_BACKEND_ACTIVE=false

TRIAL_DAYS=7
TRIAL_FEE_BPS=0
POST_TRIAL_FEE_BPS=50
PPLNS_WINDOW_HOURS=24
FEE_ADDRESS=<BTX_START_PLATFORM_FEE_ADDRESS>
TREASURY_ADDRESS=<BTX_START_PLATFORM_TREASURY_ADDRESS>

BTX_RPC_URL=http://127.0.0.1:19334
BTX_RPC_USER=<generated_rpc_user>
BTX_RPC_PASSWORD=<generated_rpc_password>

# Keep false in production until BTX matmul share validation is implemented.
ALLOW_UNVERIFIED_SHARE_ACCEPTANCE=false

# Stratum job and validation controls. Public launch requires
# SHARE_VALIDATION_MODE=solver plus a patched btx-gbt-solve binary on the host.
POOL_SHARE_TARGET_HEX=00000fffffffffffffffffffffffffffffffffffffffffffffffffffffffffff
STRATUM_JOB_REFRESH_S=20
STRATUM_NOTIFY_INTERVAL_S=10
SHARE_VALIDATION_MODE=disabled
SHARE_VALIDATION_SOLVER_PATH=/opt/btx-start/bin/btx-gbt-solve
SHARE_VALIDATION_BACKEND=cpu
SHARE_VALIDATION_SOLVER_THREADS=2
SHARE_VALIDATION_BATCH_SIZE=2
SHARE_VALIDATION_MAX_TRIES=8
SHARE_VALIDATION_MAX_SECONDS=10
BLOCK_SUBMISSION_ENABLED=false

# Observer agent. Watches public BTX peers and local btxd health. Leave apply
# mode false unless you explicitly want it to call addnode on local btxd.
NETWORK_AGENT_PEER_URL=https://peers.minebtx.com/api/peer_list?relaxed=true&n=50
NETWORK_AGENT_INTERVAL_S=60
NETWORK_AGENT_SNAPSHOT_PATH=/var/lib/btx-start/network-agent-snapshot.json
NETWORK_AGENT_MIN_SCORE=0.70
NETWORK_AGENT_APPLY_PEERS=false

# Optional Pro membership billing.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
PRO_SUCCESS_URL=https://drinknile.com/#track
PRO_CANCEL_URL=https://drinknile.com/#operating-model
